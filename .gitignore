\.*
!**/.pubignore
build
pubspec.lock
analysis_options.yaml
pubspec_overrides.yaml
**/android/local.properties
/starter/android/app/src/main/kotlin
/starter/ios/Flutter
starter/ios/Runner.xcodeproj/project.pbxproj
/node_modules
starter/node_modules
starter/package-lock.json

# IntelliJ / Android Studio module files (generated by Melos / IDE)
*.iml

# FVM Version Cache
.fvm/
 
# Allow GitHub workflows (override ".*" ignore rule)
!.github/
!.github/**

# Flutter generated files in example apps
**/example/**/Flutter/ephemeral/
**/example/**/Flutter/Generated.xcconfig
**/example/**/Flutter/flutter_export_environment.sh
**/example/**/GeneratedPluginRegistrant.h
**/example/**/GeneratedPluginRegistrant.m
**/example/**/GeneratedPluginRegistrant.java
**/example/android/app/src/main/java/io/

# Starter app generated files
starter/android/app/src/main/java/io/
starter/ios/Runner/GeneratedPluginRegistrant.h
starter/ios/Runner/GeneratedPluginRegistrant.m
starter/macos/Flutter/ephemeral/Flutter-Generated.xcconfig
starter/macos/Flutter/ephemeral/flutter_export_environment.sh

# GetStorage local persistence (runtime-generated when running starter)
starter/GetStorage.gs
starter/GetStorage.bak
starter/system.gs
starter/system.bak

# remove molos .iml files
**/melos_*.iml
